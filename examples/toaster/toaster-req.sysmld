        "symbol": "requirement",
        "layout": {
          "x": 1266,
          "y": 666,
          "width": 223,
          "height": 88,
          "z": 10
        },
        "label": "\u00abrequirement\u00bb\nREQ-T-030 Crumb Tray Force\nRemove tray with 5-15 N and\ncapture >= 90% crumbs.",
        "style": "requirement"
      },
      {
        "id": "cycleLifeRequirement",
