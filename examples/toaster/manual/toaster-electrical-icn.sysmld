      {
        "id": "button-user-in",
        "model_ref": "buttonUserInputIn",
        "symbol": "port",
        "owner": "buttons",
        "placement": { "side": "top", "offset": 0.5 },
        "label": "press"
      },
      {
        "id": "button-control-out",
        "model_ref": "buttonControlOut",
        "symbol": "port",
        "owner": "buttons",
        "placement": { "side": "bottom", "offset": 0.5 },
        "label": "ctrl"
      },
      {
        "id": "button-in",
        "model_ref": "buttonControlIn",
        "symbol": "port",
        "owner": "power-control-subsystem",
        "placement": { "side": "top", "offset": 0.43043478260869567 },
        "label": "button"
      },
      {
        "id": "subsystem-power",
        "model_ref": "subsystemPowerIn",
        "symbol": "port",
        "owner": "power-control-subsystem",
        "placement": { "side": "bottom", "offset": 0.5 },
        "label": "power"
      },
      {
        "id": "cord-in",
        "model_ref": "cordPowerIn",
        "symbol": "port",
        "owner": "power-cord",
        "placement": { "side": "bottom", "offset": 0.5 },
        "label": "in"
      },
      {
        "id": "cord-out",
        "model_ref": "cordPowerOut",
        "symbol": "port",
        "owner": "power-cord",
        "placement": { "side": "top", "offset": 0.5 },
        "label": "out"
      },
      {
        "id": "control-out",
        "model_ref": "heatCommandOut",
        "symbol": "port",
        "owner": "power-control-subsystem",
        "placement": { "side": "right", "offset": 0.5 },
        "label": "cmd"
      },
      {
        "id": "heater-in",
        "model_ref": "heaterControlIn",
        "symbol": "port",
        "owner": "heater",
        "placement": { "side": "left", "offset": 0.5 },
        "label": "cmd"
      }
    ],
    "connections": [
      {
        "id": "conn-button-input-buttons",
        "model_ref": "buttonInputToButtons",
        "source": { "element": "button-input-port", "anchor": { "side": "bottom", "offset": 0.5 } },
        "target": { "element": "button-user-in", "anchor": { "side": "top", "offset": 0.5 } },
        "route": { "kind": "orthogonal", "waypoints": [] },
        "labels": [
          { "text": "button input", "position": { "segment": 0, "offset": 0.5 } }
        ],
        "style": "connector.signal"
      },
      {
        "id": "conn-buttons-power-control",
        "model_ref": "buttonsToPowerControl",
        "source": { "element": "button-control-out", "anchor": { "side": "bottom", "offset": 0.5 } },
        "target": { "element": "button-in", "anchor": { "side": "top", "offset": 0.5 } },
        "route": {
          "kind": "orthogonal",
          "waypoints": [
            { "x": 180, "y": 220 },
            { "x": 459, "y": 220 }
          ]
        },
        "labels": [
          { "text": "button control", "position": { "segment": 0, "offset": 0.5 } }
        ],
        "style": "connector.signal"
      },
      {
        "id": "conn-mains-cord",
        "model_ref": "mainsToCord",
        "source": { "element": "mains-port", "anchor": { "side": "top", "offset": 0.5 } },
        "target": { "element": "cord-in", "anchor": { "side": "bottom", "offset": 0.5 } },
        "route": { "kind": "orthogonal", "waypoints": [] },
        "labels": [
          { "text": "mains power", "position": { "segment": 0, "offset": 0.5 } }
        ],
        "style": "connector.power"
      },
      {
        "id": "conn-cord-power-control",
        "model_ref": "cordToPowerControl",
        "source": { "element": "cord-out", "anchor": { "side": "top", "offset": 0.5 } },
        "target": { "element": "subsystem-power", "anchor": { "side": "bottom", "offset": 0.5 } },
        "route": { "kind": "orthogonal", "waypoints": [] },
        "labels": [
          { "text": "line power", "position": { "segment": 0, "offset": 0.5 } }
        ],
        "style": "connector.power"
      },
      {
        "id": "conn-lever-control",
        "model_ref": "leverToControl",
        "source": { "element": "lever-out", "anchor": { "side": "right", "offset": 0.5 } },
        "target": { "element": "control-in", "anchor": { "side": "left", "offset": 0.5 } },
        "route": { "kind": "orthogonal", "waypoints": [] },
        "labels": [
          { "text": "control", "position": { "segment": 0, "offset": 0.5 } }
        ],
        "style": "connector.signal"
      },
      {
        "id": "conn-control-heater",
        "model_ref": "controlToHeater",
        "source": { "element": "control-out", "anchor": { "side": "right", "offset": 0.5 } },
        "target": { "element": "heater-in", "anchor": { "side": "left", "offset": 0.5 } },
        "route": { "kind": "orthogonal", "waypoints": [] },
        "labels": [
          { "text": "heat command", "position": { "segment": 0, "offset": 0.5 } }
        ],
        "style": "connector.signal"
      }
    ],
    "annotations": [],
    "styles": {
      "boundary.system": {
        "fill": "#FFFFFF",
        "stroke": "#333333",
        "stroke_width": 2,
