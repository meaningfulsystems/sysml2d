  "diagram": {
    "id": "toaster-electrical-icn",
    "kind": "InterconnectionView",
    "name": "Toaster Electrical Interconnection",
    "subject": "toaster",
    "canvas": {
      "width": 1000,
      "height": 620,
      "background": "#FFFFFF"
    },
    "frame": {
      "visible": true
    },
    "elements": [
      {
        "id": "toaster-boundary",
        "model_ref": "toaster",
        "symbol": "boundary",
        "layout": { "x": 40, "y": 50, "width": 920, "height": 500, "z": 0 },
        "compartments": { "attributes": false, "ports": false, "actions": false },
        "style": "boundary.system"
      },
      {
        "id": "lever",
        "model_ref": "lever",
        "symbol": "part_usage",
        "layout": { "x": 100, "y": 240, "width": 150, "height": 90, "z": 10 },
