        "compartments": { "attributes": false, "ports": true, "actions": false },
        "style": "part.mechanical"
      },
      {
        "id": "power-control-subsystem",
        "model_ref": "powerAndControlSubsystem",
        "symbol": "part_usage",
        "layout": { "x": 360, "y": 240, "width": 230, "height": 90, "z": 10 },
        "label": "Power and Control\nSubsystem",
        "compartments": { "attributes": false, "ports": true, "actions": false },
        "style": "part.control"
      },
      {
        "id": "buttons",
        "model_ref": "buttons",
        "symbol": "part_usage",
        "layout": { "x": 100, "y": 130, "width": 160, "height": 70, "z": 10 },
        "label": "Buttons",
        "compartments": { "attributes": false, "ports": true, "actions": false },
        "style": "part.mechanical"
      },
      {
        "id": "heater",
        "model_ref": "heater",
        "symbol": "part_usage",
        "layout": { "x": 700, "y": 240, "width": 190, "height": 90, "z": 10 },
        "label": "Heating Element",
        "compartments": { "attributes": false, "ports": true, "actions": false },
        "style": "part.thermal"
      },
      {
        "id": "power-cord",
        "model_ref": "powerCord",
        "symbol": "part_usage",
        "layout": { "x": 415, "y": 400, "width": 120, "height": 70, "z": 10 },
        "label": "Power Cord",
        "compartments": { "attributes": false, "ports": true, "actions": false },
        "style": "part.electrical"
      },
      {
        "id": "button-input-port",
        "model_ref": "buttonInput",
        "symbol": "port",
        "owner": "toaster-boundary",
        "placement": { "side": "top", "offset": 0.15217391304347827 },
        "label": "Button Input"
      },
      {
        "id": "mains-port",
        "model_ref": "mainsPower",
        "symbol": "port",
        "owner": "toaster-boundary",
        "placement": { "side": "bottom", "offset": 0.47282608695652173 },
